{
  "auth_dir": "./auth_files",
  "config_path": "./config.json",
  "state_dir": "./.auto_maintain_state",
  "maintain_db_path": "./.auto_maintain_state/cpa_warden_maintain.sqlite3",
  "upload_db_path": "./.auto_maintain_state/cpa_warden_upload.sqlite3",
  "maintain_log_file": "./.auto_maintain_state/cpa_warden_maintain.log",
  "upload_log_file": "./.auto_maintain_state/cpa_warden_upload.log",
  "maintain_interval_seconds": 3600,
  "watch_interval_seconds": 15,
  "upload_stable_wait_seconds": 3,
  "upload_batch_size": 200,
  "smart_schedule_enabled": true,
  "adaptive_upload_batching": true,
  "upload_high_backlog_threshold": 600,
  "upload_high_backlog_batch_size": 300,
  "backlog_ewma_alpha": 1.0,
  "scheduler_hysteresis_enabled": false,
  "upload_high_backlog_enter_threshold": null,
  "upload_high_backlog_exit_threshold": null,
  "adaptive_maintain_batching": true,
  "incremental_maintain_batch_size": 250,
  "maintain_high_backlog_threshold": 750,
  "maintain_high_backlog_batch_size": 350,
  "maintain_high_backlog_enter_threshold": null,
  "maintain_high_backlog_exit_threshold": null,
  "next_batch_buffer_limit": null,
  "incremental_maintain_min_interval_seconds": 1,
  "incremental_maintain_full_guard_seconds": 90,
  "deep_scan_interval_loops": 120,
  "active_probe_interval_seconds": 1,
  "active_upload_deep_scan_interval_seconds": 2,
  "run_maintain_on_start": false,
  "account_lock_lease_seconds": 30,
  "run_upload_on_start": true,
  "run_maintain_after_upload": true,
  "maintain_assume_yes": true,
  "delete_uploaded_files_after_upload": true,
  "maintain_retry_count": 1,
  "upload_retry_count": 1,
  "command_retry_delay_seconds": 20,
  "continue_on_command_failure": false,
  "inprocess_execution_enabled": true,
  "allow_multi_instance": false,
  "inspect_zip_files": true,
  "auto_extract_zip_json": true,
  "delete_zip_after_extract": true,
  "archive_extensions": [".zip", ".7z", ".rar"],
  "bandizip_path": "D:\\Bandizp\\Bandizip.exe",
  "bandizip_timeout_seconds": 120,
  "use_windows_zip_fallback": true,
  "bandizip_prefer_console": true,
  "bandizip_hide_window": true
}
