{
  "auth_dir": "./auth_files",
  "config_path": "./config.json",
  "state_dir": "./.auto_maintain_state",
  "maintain_db_path": "./.auto_maintain_state/cpa_warden_maintain.sqlite3",
  "upload_db_path": "./.auto_maintain_state/cpa_warden_upload.sqlite3",
  "maintain_log_file": "./.auto_maintain_state/cpa_warden_maintain.log",
  "upload_log_file": "./.auto_maintain_state/cpa_warden_upload.log",
  "maintain_interval_seconds": 2400,
  "watch_interval_seconds": 15,
  "upload_stable_wait_seconds": 5,
  "upload_batch_size": 100,
  "deep_scan_interval_loops": 120,
  "run_maintain_on_start": true,
  "run_upload_on_start": true,
  "run_maintain_after_upload": true,
  "maintain_assume_yes": true,
  "delete_uploaded_files_after_upload": true,
  "maintain_retry_count": 1,
  "upload_retry_count": 1,
  "command_retry_delay_seconds": 20,
  "continue_on_command_failure": false,
  "allow_multi_instance": false,
  "inspect_zip_files": true,
  "auto_extract_zip_json": true,
  "delete_zip_after_extract": true,
  "bandizip_path": "D:\\Bandizp\\Bandizip.exe",
  "bandizip_timeout_seconds": 120,
  "use_windows_zip_fallback": true
}
